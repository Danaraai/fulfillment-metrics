# Copy this file to .streamlit/secrets.toml and fill in the values.
# On Streamlit Cloud, add the contents of gcp_service_account in the app's Secrets section.
# NEVER commit secrets.toml to git.

# Paste the entire service account JSON as a single-line string:
gcp_service_account = '{"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"YOUR_SA@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}'
